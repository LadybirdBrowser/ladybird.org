---
import {
  currentSponsors,
  type SponsorTier,
} from "@/components/landing/sponsors";

type Props = {
  sponsors?: SponsorTier[];
  heading?: string;
  id?: string;
  description?: string;
  previousSponsorsLink?: boolean;
};

const {
  sponsors = currentSponsors,
  heading = "Sponsors",
  id = "sponsors",
  description,
  previousSponsorsLink = false,
} = Astro.props;

const hasLogos = (tier: SponsorTier) => tier.sponsors.some((s) => s.logo);
---

<section id={id} class="section">
  <div class="container">
    <h2 class="section-heading">{heading}</h2>
    {description && <p class="sponsors-description">{description}</p>}

    {
      sponsors.map((tier) => (
        <div class="tier">
          <h4 class="tier-name">{tier.name}</h4>
          {hasLogos(tier) ? (
            <div class="tier-logos">
              {tier.sponsors.map((s) => (
                <div class="logo-card">
                  {s.href ? (
                    <a href={s.href} rel="nofollow">
                      {s.logo ? (
                        <img
                          class:list={[s.logoClass]}
                          src={s.logo}
                          alt={s.name}
                        />
                      ) : (
                        <span class="card-name">{s.name}</span>
                      )}
                    </a>
                  ) : s.logo ? (
                    <img class:list={[s.logoClass]} src={s.logo} alt={s.name} />
                  ) : (
                    <span class="card-name">{s.name}</span>
                  )}
                </div>
              ))}
            </div>
          ) : (
            <p class="tier-text">
              {tier.sponsors.map((s, i) => (
                <span class="tier-text-item">
                  {s.href ? (
                    <a href={s.href} rel="nofollow">
                      {s.name}
                    </a>
                  ) : (
                    s.name
                  )}
                  {i < tier.sponsors.length - 1 && (
                    <span aria-hidden="true">,</span>
                  )}
                </span>
              ))}
            </p>
          )}
        </div>
      ))
    }

    {
      previousSponsorsLink && (
        <p class="previous-sponsors-link">
          <a class="btn btn--outline" href="/previous-sponsors/">
            Previous sponsors
          </a>
        </p>
      )
    }
  </div>
</section>

<style>
  .sponsors-description {
    margin-top: -12px;
    margin-bottom: 32px;
    color: var(--text-muted);
    font-size: 15px;
    line-height: 1.7;
  }

  .tier {
    margin-bottom: 32px;
  }

  .tier:last-child {
    margin-bottom: 0;
  }

  .tier-name {
    margin-bottom: 12px;
    color: var(--text-muted);
    font-weight: var(--weight-medium);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .tier-logos {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: center;
  }

  .logo-card {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px 20px;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 6px;
    min-height: 56px;
  }

  .logo-card a {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: var(--text-primary);
  }

  .logo-card img {
    max-height: 28px;
    max-width: 120px;
    object-fit: contain;
  }

  .logo-card img.sponsor-logo--large {
    height: 28px;
    max-width: 120px;
    max-height: 28px;
  }

  .card-name {
    font-size: 14px;
    font-weight: var(--weight-medium);
    color: var(--text-primary);
    white-space: nowrap;
  }

  .tier-text {
    display: flex;
    flex-wrap: wrap;
    column-gap: 0.35em;
    font-size: 14px;
    line-height: 1.8;
  }

  .tier-text-item {
    display: inline-flex;
  }

  .tier-text-item a {
    display: inline-flex;
  }

  .previous-sponsors-link {
    margin-top: 32px;
  }

  @media (max-width: 640px) {
    .tier-logos {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .logo-card {
      padding: 10px 12px;
      min-height: 44px;
      min-width: 0;
    }

    .logo-card img {
      max-height: 22px;
      max-width: 100px;
    }

    .logo-card img.sponsor-logo--large {
      height: 22px;
      max-width: 100px;
      max-height: 22px;
    }

    .card-name {
      font-size: 12px;
      white-space: normal;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .tier-text {
      font-size: 13px;
    }

    .sponsors-description {
      font-size: 13px;
    }
  }
</style>
